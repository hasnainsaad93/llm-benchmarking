generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LLMModel {
  OPENAI
  ANTHROPIC
}

enum SentimentLabel {
  POSITIVE
  NEGATIVE
  NEUTRAL
}

model Post {
  id         String         @id @default(cuid())
  externalId String?        @unique
  text       String
  model      LLMModel
  sentiment  SentimentLabel
  createdAt  DateTime       @default(now())
}

model Feedback {
  id        String   @id @default(cuid())
  name      String
  email     String
  model     LLMModel
  createdAt DateTime @default(now())
}
